# ──────────────────────────────────────────────
# Cortex — Environment Variables
# Copy to .env and fill in secrets before running
# ──────────────────────────────────────────────

# ── General ──────────────────────────────────
ENVIRONMENT=development

# ── LLM ──────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-flash-latest
LLM_API_KEY=            # your Gemini API key

# ── Embeddings ───────────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_API_KEY=      # can be the same as LLM_API_KEY for Gemini

# ── Vector DB (pgvector) ─────────────────────
VECTOR_DB_PROVIDER=pgvector
# Note: DB_HOST and VECTOR_DB_URL are overridden by docker-compose.
# These localhost values only apply when running without Docker.
VECTOR_DB_URL=postgresql://postgres:postgres@localhost:5432/cortex

# ── Database ─────────────────────────────────
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cortex
DB_USER=postgres
DB_PASSWORD=postgres

# ── Supabase (optional — for legacy services) ─
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Webhooks (optional) ─────────────────────
WEBHOOK_BASE_URL=http://localhost:8000
WEBHOOK_SECRET=
